  "author": "pilotpirxie <10637666+pilotpirxie@users.noreply.github.com>",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^24.1.0",
    "body-parser": "^2.2.2",
    "jsonwebtoken": "^9.0.2",
    "knip": "^6.2.0",
    "node-cache": "^5.1.2",
    "prettier": "3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "fix": "prettier --write .",
    "dev": "ts-node ./example/app.ts",
    "minimal": "ts-node ./example/minimal.ts",
    "multiple": "ts-node ./example/multiple.ts",
    "middlewares": "ts-node ./example/middlewares.ts",
    "build": "tsc",
    "prepare": "tsc",
    "test": "tsc --noEmit && tsc --noEmit -p tsconfig.spec.json && tsc --noEmit -p tsconfig.example.json && node --import tsx --test --experimental-test-coverage \"src/**/*.spec.ts\" \"examples/**/*.spec.ts\"",
